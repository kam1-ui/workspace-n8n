# ===========================================
# Example .env for n8n (Nginx proxy, no Traefik)
# ===========================================
# Copiez vers .env et remplissez vos vraies valeurs
# Les services Postgres/Redis sont dans /root/docker-compose.yml

# --- Database (Postgres) ---
POSTGRES_USER=n8n
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=n8n

# --- n8n Main ---
N8N_IMAGE=docker.n8n.io/n8nio/n8n:1.123.6
N8N_HOST=n8n.chnnlcrypto.cloud
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.chnnlcrypto.cloud/
N8N_ENCRYPTION_KEY=CHANGEME
N8N_SECURE_COOKIE=false
N8N_USER_FOLDER=/home/node/.n8n

# --- Redis (container: n8n-redis sur root_default) ---
QUEUE_BULL_REDIS_HOST=n8n-redis
QUEUE_BULL_REDIS_PORT=6379

# --- n8n DB connection (container: n8n-postgres sur root_default) ---
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=n8n-postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=CHANGEME

# --- Queue mode ---
EXECUTIONS_MODE=queue

# --- Task runners ---
N8N_RUNNERS_ENABLED=true

# --- Permissions ---
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true

# --- Modules Node.js autorisés ---
NODE_FUNCTION_ALLOW_BUILTIN=*
N8N_TRUST_PROXY=true
EXECUTIONS_CONCURRENCY=2
N8N_COMMUNITY_PACKAGES_ENABLED=true
NODE_FUNCTION_ALLOW_EXTERNAL=*
