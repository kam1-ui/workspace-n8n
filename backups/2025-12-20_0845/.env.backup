# .env for n8n + Nginx + Postgres + Redis

POSTGRES_USER=n8n
POSTGRES_PASSWORD='REDACTED'
POSTGRES_DB=n8n

N8N_IMAGE=docker.n8n.io/n8nio/n8n:1.123.6
N8N_HOST=n8n.chnnlcrypto.cloud
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.chnnlcrypto.cloud/
N8N_ENCRYPTION_KEY=REDACTED
N8N_SECURE_COOKIE=false
N8N_USER_FOLDER=/home/node/.n8n

QUEUE_BULL_REDIS_HOST=redis
QUEUE_BULL_REDIS_PORT=6379

DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD='REDACTED'

EXECUTIONS_MODE=queue
N8N_RUNNERS_ENABLED=true
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true

EXECUTIONS_CONCURRENCY=2
