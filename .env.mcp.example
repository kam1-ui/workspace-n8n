# MCP Server Configuration - EXEMPLE
# Copiez ce fichier vers .env.mcp et remplissez vos vraies valeurs

# Authentification MCP (générer avec: openssl rand -base64 32)
AUTH_TOKEN=your_bearer_token_here

# Configuration n8n API
# Obtenir depuis: https://n8n.chnnlcrypto.cloud/settings/api
N8N_API_KEY=your_n8n_api_key_here
N8N_API_URL=https://n8n.chnnlcrypto.cloud

# Configuration serveur
BASE_URL=https://mcp.chnnlcrypto.cloud
